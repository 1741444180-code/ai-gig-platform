# Application environment variables (copy to .env)
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_gig
APP_DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_gig
APP_DB_POOL_SIZE=10
APP_DB_MAX_OVERFLOW=20

# JWT — 生产环境务必修改 SECRET_KEY
APP_SECRET_KEY=your-secret-key-change-me-in-production
APP_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=30

# WeChat (小程序/公众号)
APP_WECHAT_APP_ID=
APP_WECHAT_APP_SECRET=

# AI / DashScope (通义千问)
APP_DASHSCOPE_API_KEY=
APP_QWEN_API_KEY=
APP_AI_MODEL=qwen-plus
APP_QWEN_MODEL=qwen-plus

# 平台业务配置
APP_PLATFORM_FEE_RATE=0.10
APP_MAX_MODIFY_TIMES=3

# App
APP_APP_ENV=development
APP_DEBUG=true
